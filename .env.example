

# --- Database (docker compose defaults) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vector_db

# --- LlamaIndex / RAG ---
# Vector table name (PGVectorStore)
VECTOR_TABLE_NAME=raporty_finansowe_hybrid

# --- API security / limits ---
DEMO_PASSWORD=
MAX_UPLOAD_FILE_SIZE_MB=100

# LLM provider (code uses LLM_PROVIDER_QUERY + LLM_PROVIDER_SYNTHESIS)
# Values: groq|openai
LLM_PROVIDER_QUERY=groq
LLM_PROVIDER_SYNTHESIS=openai

# (legacy, not used by current code)
LLM_PROVIDER=groq


GROQ_API_KEY=
OPENAI_API_KEY=

LLAMAPARSE_API_KEY=

# --- Embeddings (no local models) ---
# Providers: openai|voyage|mock
EMBEDDINGS_PROVIDER=openai
EMBEDDINGS_MODEL=text-embedding-3-small
# Must match model dimension and PGVector table dimension
EMBEDDINGS_DIM=1536
VOYAGE_API_KEY=

# --- Reranking (no local models) ---
# Providers: llm|none
RERANK_PROVIDER=llm
RERANK_TOP_N=10

# --- GUI ---
# Local run: http://localhost:8000
# Docker compose: http://api:8000 (set in compose automatically)
API_URL=http://localhost:8000

# --- LangSmith (optional, only if you use it) ---
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING_V2=true
# LANGSMITH_PROJECT=SmartDocsAnalyzer
